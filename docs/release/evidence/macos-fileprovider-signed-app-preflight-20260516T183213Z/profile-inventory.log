fi
if [[ -n "${KEYCHAIN_GROUP_SUFFIX:-}" ]]; then
  args+=(--keychain-group-suffix "$KEYCHAIN_GROUP_SUFFIX")
fi
if [[ "${STRICT:-0}" == "1" ]]; then
  args+=(--strict)
fi

scripts/macos-fileprovider-profile-inventory.sh "${args[@]}"
