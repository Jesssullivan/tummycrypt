task: [lazy:macos-pkg-structure-smoke] bash -euo pipefail <<'EOF'
: "${PKG_PATH:?set PKG_PATH=/path/to/tcfs.pkg}"

args=(--pkg "$PKG_PATH")
if [[ -n "${EXPECTED_POSTINSTALL:-}" ]]; then
  args+=(--expected-postinstall "$EXPECTED_POSTINSTALL")
fi
if [[ "${REQUIRE_SIGNATURE:-0}" == "1" ]]; then
  args+=(--require-signature)
fi
if [[ "${REQUIRE_GATEKEEPER_INSTALL:-0}" == "1" ]]; then
  args+=(--require-gatekeeper-install)
fi
if [[ "${REQUIRE_STAPLED_TICKET:-0}" == "1" ]]; then
  args+=(--require-stapled-ticket)
fi

scripts/macos-pkg-structure-smoke.sh "${args[@]}"
EOF

